<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
    <title>Property Tracker – Shop & Room Manager</title>

    <!-- ========== PWA META TAGS ========== -->
    <link rel="manifest" href="manifest.json" />
    <meta name="theme-color" content="#1a1a2e" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📦</text></svg>" />

    <style>
        /* ========== RESET & BASE ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            color: #e0e0e0;
            min-height: 100vh;
            padding: 20px;
            background-attachment: fixed;
        }

        /* Animated background particles effect */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background:
                radial-gradient(2px 2px at 20% 30%, #fff, transparent),
                radial-gradient(2px 2px at 40% 70%, #fff, transparent),
                radial-gradient(2px 2px at 60% 20%, #fff, transparent),
                radial-gradient(2px 2px at 80% 60%, #fff, transparent),
                radial-gradient(2px 2px at 10% 80%, #fff, transparent),
                radial-gradient(2px 2px at 90% 10%, #fff, transparent),
                radial-gradient(2px 2px at 50% 50%, #fff, transparent),
                radial-gradient(2px 2px at 70% 80%, #fff, transparent),
                radial-gradient(2px 2px at 30% 40%, #fff, transparent),
                radial-gradient(2px 2px at 85% 30%, #fff, transparent);
            background-size: 200px 200px;
            background-repeat: repeat;
            opacity: 0.15;
            pointer-events: none;
            z-index: 0;
            animation: twinkle 4s ease-in-out infinite alternate;
        }

        @keyframes twinkle {
            0% {
                opacity: 0.1;
            }
            100% {
                opacity: 0.25;
            }
        }

        .app-container {
            max-width: 1100px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* ========== INSTALL BANNER ========== */
        .install-banner {
            background: rgba(255, 215, 0, 0.1);
            border: 1px solid rgba(255, 215, 0, 0.2);
            border-radius: 16px;
            padding: 16px 20px;
            margin-bottom: 20px;
            display: none;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            backdrop-filter: blur(20px);
            animation: slideDown 0.5s ease;
        }

        .install-banner.show {
            display: flex;
        }

        .install-banner .icon {
            font-size: 2rem;
        }

        .install-banner .message {
            flex: 1;
            font-weight: 600;
        }

        .install-banner .message small {
            display: block;
            font-weight: 400;
            opacity: 0.6;
            font-size: 0.85rem;
        }

        .install-banner .btn {
            padding: 10px 24px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-install {
            background: linear-gradient(135deg, #f7971e, #ffd200);
            color: #1a1a2e;
        }

        .btn-install:hover {
            transform: scale(1.05);
        }

        .btn-close-install {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.6);
        }

        .btn-close-install:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        /* ========== HEADER ========== */
        .header {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 30px 35px;
            color: white;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .header h1 {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #f7971e, #ffd200);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header h1 span {
            -webkit-text-fill-color: white;
            background: none;
        }

        .header .subtitle {
            font-size: 0.85rem;
            opacity: 0.7;
            -webkit-text-fill-color: rgba(255, 255, 255, 0.7);
        }

        .header-stats {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
            background: rgba(255, 255, 255, 0.08);
            padding: 8px 20px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
        }

        .stat-item .number {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffd700;
        }

        .stat-item .label {
            font-size: 0.7rem;
            opacity: 0.7;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ========== NAV TABS ========== */
        .nav-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(20px);
            padding: 8px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .nav-tab {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: 0.3s;
            background: transparent;
            color: rgba(255, 255, 255, 0.6);
            flex: 1;
            backdrop-filter: blur(10px);
        }

        .nav-tab:hover {
            background: rgba(255, 255, 255, 0.08);
            color: white;
        }

        .nav-tab.active {
            background: linear-gradient(135deg, #f7971e, #ffd200);
            color: #1a1a2e;
            box-shadow: 0 4px 20px rgba(247, 151, 30, 0.3);
        }

        .nav-tab .badge {
            display: inline-block;
            background: #ff5252;
            color: white;
            border-radius: 40px;
            padding: 0 8px;
            font-size: 0.7rem;
            margin-left: 6px;
        }

        .nav-tab.active .badge {
            background: #1a1a2e;
            color: #ffd700;
        }

        /* ========== ALERT BANNER ========== */
        .alert-banner {
            background: rgba(255, 235, 238, 0.15);
            backdrop-filter: blur(20px);
            border-left: 5px solid #ff5252;
            padding: 14px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: none;
            align-items: center;
            gap: 14px;
            animation: slideDown 0.4s ease;
            border: 1px solid rgba(255, 82, 82, 0.2);
        }

        .alert-banner.show {
            display: flex;
        }

        .alert-banner .icon {
            font-size: 1.8rem;
        }

        .alert-banner .message {
            flex: 1;
            font-weight: 600;
            color: #ff8a80;
        }

        .alert-banner .dismiss {
            background: none;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            color: #ff8a80;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ========== PAGE CONTENT ========== */
        .page {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .page.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ========== CONTROLS ========== */
        .controls {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(20px);
            padding: 16px 20px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .controls input,
        .controls select {
            padding: 10px 16px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            font-size: 0.95rem;
            flex: 1;
            min-width: 150px;
            outline: none;
            transition: 0.3s;
            background: rgba(255, 255, 255, 0.05);
            color: #e0e0e0;
        }

        .controls input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .controls input:focus,
        .controls select:focus {
            border-color: #ffd700;
            box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.15);
            background: rgba(255, 255, 255, 0.08);
        }

        .controls select option {
            background: #1a1a2e;
            color: #e0e0e0;
        }

        .controls .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #f7971e, #ffd200);
            color: #1a1a2e;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(247, 151, 30, 0.3);
        }

        .btn-success {
            background: linear-gradient(135deg, #00b894, #00cec9);
            color: white;
        }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(0, 206, 201, 0.3);
        }

        .btn-danger {
            background: linear-gradient(135deg, #ff6b6b, #ee5a24);
            color: white;
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(238, 90, 36, 0.3);
        }

        .btn-warning {
            background: linear-gradient(135deg, #fdcb6e, #f39c12);
            color: #1a1a2e;
        }

        .btn-warning:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(243, 156, 18, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid rgba(255, 215, 0, 0.5);
            color: #ffd700;
        }

        .btn-outline:hover {
            background: rgba(255, 215, 0, 0.1);
            transform: translateY(-2px);
        }

        .btn-sm {
            padding: 6px 14px;
            font-size: 0.8rem;
        }

        /* ========== MODAL ========== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(8px);
            z-index: 999;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-radius: 24px;
            padding: 32px;
            max-width: 500px;
            width: 100%;
            animation: popIn 0.3s ease;
            max-height: 90vh;
            overflow-y: auto;
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        @keyframes popIn {
            from {
                transform: scale(0.9) translateY(20px);
                opacity: 0;
            }
            to {
                transform: scale(1) translateY(0);
                opacity: 1;
            }
        }

        .modal h2 {
            font-size: 1.5rem;
            color: #ffd700;
            margin-bottom: 20px;
        }

        .modal .form-group {
            margin-bottom: 16px;
        }

        .modal .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.7);
        }

        .modal .form-group input,
        .modal .form-group select,
        .modal .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            font-size: 0.95rem;
            outline: none;
            transition: 0.3s;
            font-family: inherit;
            background: rgba(255, 255, 255, 0.05);
            color: #e0e0e0;
        }

        .modal .form-group input:focus,
        .modal .form-group select:focus,
        .modal .form-group textarea:focus {
            border-color: #ffd700;
            box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.1);
        }

        .modal .form-group textarea {
            resize: vertical;
            min-height: 60px;
        }

        .modal .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .modal .form-actions .btn {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            font-size: 1rem;
        }

        .modal .form-actions .btn-cancel {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.6);
        }

        .modal .form-actions .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        /* ========== PROPERTY GRID ========== */
        .property-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
            margin-top: 20px;
        }

        .property-card {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(20px);
            border-radius: 16px;
            padding: 18px 20px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.3s ease;
            position: relative;
        }

        .property-card:hover {
            transform: translateY(-4px);
            border-color: rgba(255, 215, 0, 0.2);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
            background: rgba(255, 255, 255, 0.08);
        }

        .property-card .status-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            padding: 4px 14px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-present {
            background: rgba(0, 206, 201, 0.2);
            color: #00cec9;
            border: 1px solid rgba(0, 206, 201, 0.2);
        }

        .status-missing {
            background: rgba(255, 82, 82, 0.2);
            color: #ff8a80;
            border: 1px solid rgba(255, 82, 82, 0.2);
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.03);
            }
        }

        .property-card .icon {
            font-size: 2rem;
            margin-bottom: 6px;
        }

        .property-card h3 {
            font-size: 1.1rem;
            color: white;
            margin-bottom: 2px;
        }

        .property-card .category {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.5);
            display: inline-block;
            background: rgba(255, 255, 255, 0.05);
            padding: 2px 12px;
            border-radius: 40px;
        }

        .property-card .location {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.6);
            margin: 6px 0;
        }

        .property-card .notes {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.4);
            margin: 6px 0;
            font-style: italic;
        }

        .property-card .card-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            flex-wrap: wrap;
        }

        .property-card .card-actions .btn {
            padding: 6px 14px;
            border: none;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-checkin {
            background: rgba(0, 206, 201, 0.2);
            color: #00cec9;
        }

        .btn-checkin:hover {
            background: rgba(0, 206, 201, 0.3);
        }

        .btn-checkout {
            background: rgba(255, 82, 82, 0.2);
            color: #ff8a80;
        }

        .btn-checkout:hover {
            background: rgba(255, 82, 82, 0.3);
        }

        .btn-edit {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.7);
        }

        .btn-edit:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .btn-delete {
            background: rgba(255, 82, 82, 0.1);
            color: #ff8a80;
        }

        .btn-delete:hover {
            background: rgba(255, 82, 82, 0.2);
        }

        /* ========== SHOPPING LIST ========== */
        .shopping-summary {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 16px;
            padding: 16px 20px;
            background: rgba(255, 215, 0, 0.08);
            border-radius: 12px;
            border: 1px solid rgba(255, 215, 0, 0.1);
            backdrop-filter: blur(10px);
        }

        .shopping-summary .total-label {
            font-weight: 600;
            color: rgba(255, 255, 255, 0.6);
        }

        .shopping-summary .total-amount {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffd700;
            margin-left: auto;
        }

        .shopping-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 12px;
            margin-bottom: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: 0.3s;
        }

        .shopping-item:hover {
            border-color: rgba(255, 215, 0, 0.15);
            background: rgba(255, 255, 255, 0.06);
        }

        .shopping-item .checkbox {
            width: 22px;
            height: 22px;
            accent-color: #ffd700;
            cursor: pointer;
        }

        .shopping-item .item-info {
            flex: 1;
        }

        .shopping-item .item-info .name {
            font-weight: 600;
            color: white;
        }

        .shopping-item .item-info .details {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.5);
        }

        .shopping-item .item-price {
            font-weight: 700;
            color: #ffd700;
            margin-right: 10px;
            min-width: 80px;
            text-align: right;
        }

        .shopping-item .item-actions {
            display: flex;
            gap: 6px;
        }

        .shopping-item .item-actions .btn {
            padding: 4px 10px;
            border: none;
            border-radius: 6px;
            font-size: 0.7rem;
            cursor: pointer;
            transition: 0.3s;
        }

        .shopping-item.purchased {
            opacity: 0.4;
            text-decoration: line-through;
        }

        .shopping-item.purchased .name {
            color: rgba(255, 255, 255, 0.3);
        }

        .shopping-item.purchased .item-price {
            color: rgba(255, 215, 0, 0.3);
        }

        /* ========== EMPTY STATE ========== */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.4);
        }

        .empty-state .icon {
            font-size: 4rem;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        .empty-state h3 {
            font-size: 1.4rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 8px;
        }

        /* ========== TOAST ========== */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(20px);
            color: white;
            padding: 14px 28px;
            border-radius: 60px;
            font-weight: 600;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
            z-index: 1000;
            animation: toastIn 0.4s ease;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .toast.success {
            border-color: rgba(0, 206, 201, 0.3);
        }

        .toast.warning {
            border-color: rgba(255, 215, 0, 0.3);
        }

        .toast.error {
            border-color: rgba(255, 82, 82, 0.3);
        }

        @keyframes toastIn {
            from {
                opacity: 0;
                transform: translateX(-50%) translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }
        }

        /* ========== SCROLLBAR ========== */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255, 215, 0, 0.3);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 215, 0, 0.5);
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 600px) {
            .header {
                flex-direction: column;
                text-align: center;
                padding: 20px;
            }

            .header h1 {
                font-size: 1.5rem;
            }

            .header-stats {
                justify-content: center;
            }

            .nav-tabs {
                flex-direction: column;
            }

            .nav-tab {
                text-align: center;
            }

            .controls {
                flex-direction: column;
            }

            .controls input,
            .controls select {
                min-width: 100%;
            }

            .modal {
                padding: 20px;
                margin: 10px;
            }

            .property-grid {
                grid-template-columns: 1fr;
            }

            .shopping-item {
                flex-wrap: wrap;
            }

            .shopping-item .item-actions {
                width: 100%;
                justify-content: flex-end;
            }

            .shopping-item .item-price {
                min-width: auto;
                text-align: left;
            }

            .shopping-summary {
                flex-direction: column;
                text-align: center;
            }

            .shopping-summary .total-amount {
                margin-left: 0;
            }

            .install-banner {
                flex-direction: column;
                text-align: center;
            }
        }
    </style>
</head>
<body>

    <div class="app-container">

        <!-- ========== INSTALL BANNER (PWA) ========== -->
        <div class="install-banner" id="installBanner">
            <span class="icon">📦</span>
            <div class="message">
                Install Property Tracker
                <small>Add to home screen for faster access and offline use</small>
            </div>
            <button class="btn btn-install" id="installBtn">📱 Install App</button>
            <button class="btn btn-close-install" onclick="closeInstallBanner()">✕</button>
        </div>

        <!-- ========== HEADER ========== -->
        <header class="header">
            <div>
                <h1>📦 Property <span>Tracker</span></h1>
                <p class="subtitle">Manage your shop or room inventory</p>
            </div>
            <div class="header-stats">
                <div class="stat-item">
                    <div class="number" id="totalItems">0</div>
                    <div class="label">Total</div>
                </div>
                <div class="stat-item">
                    <div class="number" id="presentItems">0</div>
                    <div class="label">✅ Present</div>
                </div>
                <div class="stat-item">
                    <div class="number" id="missingItems">0</div>
                    <div class="label">❌ Missing</div>
                </div>
            </div>
        </header>

        <!-- ========== ALERT BANNER ========== -->
        <div class="alert-banner" id="alertBanner">
            <span class="icon">🚨</span>
            <span class="message" id="alertMessage">Some items are missing from your inventory!</span>
            <button class="dismiss" onclick="dismissAlert()">✕</button>
        </div>

        <!-- ========== NAV TABS ========== -->
        <div class="nav-tabs">
            <button class="nav-tab active" onclick="switchPage('inventory')">
                📦 Inventory <span class="badge" id="inventoryBadge">0</span>
            </button>
            <button class="nav-tab" onclick="switchPage('shopping')">
                🛒 Shopping List <span class="badge" id="shoppingBadge">0</span>
            </button>
        </div>

        <!-- ========== PAGE 1: INVENTORY ========== -->
        <div class="page active" id="page-inventory">

            <div class="controls">
                <input type="text" id="searchInput" placeholder="🔍 Search property..." oninput="renderProperties()" />
                <select id="filterStatus" onchange="renderProperties()">
                    <option value="all">All Items</option>
                    <option value="present">✅ Present</option>
                    <option value="missing">❌ Missing</option>
                </select>
                <select id="filterCategory" onchange="renderProperties()">
                    <option value="all">All Categories</option>
                    <option value="Electronics">📱 Electronics</option>
                    <option value="Furniture">🪑 Furniture</option>
                    <option value="Clothing">👕 Clothing</option>
                    <option value="Books">📚 Books</option>
                    <option value="Tools">🔧 Tools</option>
                    <option value="Food">🍕 Food</option>
                    <option value="Other">📦 Other</option>
                </select>
                <button class="btn btn-primary" onclick="openAddModal()">➕ Add Property</button>
                <button class="btn btn-warning" onclick="exportData()">📤 Export</button>
                <button class="btn btn-outline" onclick="importData()">📥 Import</button>
                <input type="file" id="fileInput" accept=".json" style="display:none" onchange="handleImport(event)" />
            </div>

            <div id="propertyGrid" class="property-grid">
                <!-- Rendered by JavaScript -->
            </div>

        </div>

        <!-- ========== PAGE 2: SHOPPING LIST ========== -->
        <div class="page" id="page-shopping">

            <div class="controls">
                <input type="text" id="shoppingSearch" placeholder="🔍 Search shopping list..." oninput="renderShoppingList()" />
                <button class="btn btn-primary" onclick="openShoppingModal()">➕ Add to Shopping List</button>
                <button class="btn btn-success" onclick="clearPurchased()">🗑️ Clear Purchased</button>
            </div>

            <!-- Shopping Summary -->
            <div class="shopping-summary" id="shoppingSummary">
                <span class="total-label">💰 Total Estimated Cost</span>
                <span class="total-amount" id="totalAmount">₦0</span>
            </div>

            <div id="shoppingGrid">
                <!-- Rendered by JavaScript -->
            </div>

        </div>

        <!-- ========== ADD PROPERTY MODAL ========== -->
        <div class="modal-overlay" id="addModal">
            <div class="modal">
                <h2 id="modalTitle">➕ Add New Property</h2>
                <form id="propertyForm" onsubmit="saveProperty(event)">
                    <input type="hidden" id="editId" value="" />

                    <div class="form-group">
                        <label>Item Name *</label>
                        <input type="text" id="itemName" required placeholder="e.g., Laptop, Chair, Book" />
                    </div>

                    <div class="form-group">
                        <label>Category</label>
                        <select id="itemCategory">
                            <option value="Electronics">📱 Electronics</option>
                            <option value="Furniture">🪑 Furniture</option>
                            <option value="Clothing">👕 Clothing</option>
                            <option value="Books">📚 Books</option>
                            <option value="Tools">🔧 Tools</option>
                            <option value="Food">🍕 Food</option>
                            <option value="Other">📦 Other</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" id="itemLocation" placeholder="e.g., Shelf A, Room 1, Counter" />
                    </div>

                    <div class="form-group">
                        <label>Status</label>
                        <select id="itemStatus">
                            <option value="present">✅ Present</option>
                            <option value="missing">❌ Missing</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Notes (Optional)</label>
                        <textarea id="itemNotes" placeholder="Additional details..." rows="2"></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn btn-cancel" onclick="closeModal('addModal')">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="saveBtn">💾 Save Property</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ========== SHOPPING LIST MODAL ========== -->
        <div class="modal-overlay" id="shoppingModal">
            <div class="modal">
                <h2>🛒 Add to Shopping List</h2>
                <form id="shoppingForm" onsubmit="saveShoppingItem(event)">
                    <input type="hidden" id="shoppingEditId" value="" />

                    <div class="form-group">
                        <label>Item Name *</label>
                        <input type="text" id="shoppingName" required placeholder="e.g., New Laptop, Office Chair" />
                    </div>

                    <div class="form-group">
                        <label>Category</label>
                        <select id="shoppingCategory">
                            <option value="Electronics">📱 Electronics</option>
                            <option value="Furniture">🪑 Furniture</option>
                            <option value="Clothing">👕 Clothing</option>
                            <option value="Books">📚 Books</option>
                            <option value="Tools">🔧 Tools</option>
                            <option value="Food">🍕 Food</option>
                            <option value="Other">📦 Other</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Estimated Price *</label>
                        <input type="text" id="shoppingPrice" required placeholder="e.g., ₦500,000, $1,200" />
                    </div>

                    <div class="form-group">
                        <label>Notes (Optional)</label>
                        <textarea id="shoppingNotes" placeholder="Additional details..." rows="2"></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn btn-cancel" onclick="closeModal('shoppingModal')">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="shoppingSaveBtn">💾 Add to List</button>
                    </div>
                </form>
            </div>
        </div>

    </div>

    <script>
        // ============================================================
        // DATA LAYER
        // ============================================================
        let properties = [];
        let shoppingItems = [];

        function loadData() {
            const storedProps = localStorage.getItem('properties');
            if (storedProps) {
                try { properties = JSON.parse(storedProps); } catch { properties = []; }
            } else {
                properties = [
                    { id: 1, name: 'MacBook Pro', category: 'Electronics', location: 'Desk A', status: 'present',
                        notes: 'Work laptop' },
                    { id: 2, name: 'Office Chair', category: 'Furniture', location: 'Room 1', status: 'present',
                        notes: 'Black leather' },
                    { id: 3, name: 'Whiteboard Marker', category: 'Tools', location: 'Whiteboard tray',
                        status: 'missing', notes: 'Need to replace' },
                    { id: 4, name: 'Harry Potter Book', category: 'Books', location: 'Shelf B', status: 'present',
                        notes: 'Fiction' },
                    { id: 5, name: 'Calculator', category: 'Electronics', location: 'Drawer 2', status: 'present',
                        notes: 'Scientific' },
                ];
                saveData();
            }

            const storedShopping = localStorage.getItem('shoppingItems');
            if (storedShopping) {
                try { shoppingItems = JSON.parse(storedShopping); } catch { shoppingItems = []; }
            } else {
                shoppingItems = [
                    { id: 101, name: 'New Desk', category: 'Furniture', price: '₦150,000', notes: 'For home office',
                        purchased: false },
                    { id: 102, name: 'Wireless Mouse', category: 'Electronics', price: '₦15,000',
                        notes: 'Logitech MX Master', purchased: false },
                    { id: 103, name: 'Printer Paper', category: 'Other', price: '₦5,000', notes: 'A4 500 sheets',
                        purchased: true },
                ];
                saveData();
            }
        }

        function saveData() {
            localStorage.setItem('properties', JSON.stringify(properties));
            localStorage.setItem('shoppingItems', JSON.stringify(shoppingItems));
        }

        function generateId() {
            return Date.now() + Math.random() * 1000;
        }

        // ============================================================
        // PAGE SWITCHING
        // ============================================================
        function switchPage(page) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));

            document.getElementById('page-' + page).classList.add('active');
            document.querySelectorAll('.nav-tab').forEach(t => {
                if (t.textContent.includes(page === 'inventory' ? 'Inventory' : 'Shopping')) {
                    t.classList.add('active');
                }
            });

            if (page === 'inventory') renderProperties();
            if (page === 'shopping') renderShoppingList();
        }

        // ============================================================
        // INVENTORY: RENDER
        // ============================================================
        function renderProperties() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const statusFilter = document.getElementById('filterStatus').value;
            const categoryFilter = document.getElementById('filterCategory').value;

            let filtered = properties.filter(p => {
                const matchesSearch = p.name.toLowerCase().includes(search) ||
                    p.category.toLowerCase().includes(search) ||
                    p.location.toLowerCase().includes(search);
                const matchesStatus = statusFilter === 'all' || p.status === statusFilter;
                const matchesCategory = categoryFilter === 'all' || p.category === categoryFilter;
                return matchesSearch && matchesStatus && matchesCategory;
            });

            const grid = document.getElementById('propertyGrid');

            if (filtered.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state" style="grid-column: 1 / -1;">
                        <div class="icon">📭</div>
                        <h3>No Properties Found</h3>
                        <p>Add your first property or adjust your filters.</p>
                        <button class="btn btn-primary" onclick="openAddModal()" style="margin-top:12px;">➕ Add Property</button>
                    </div>
                `;
            } else {
                grid.innerHTML = filtered.map(p => `
                    <div class="property-card">
                        <span class="status-badge ${p.status === 'present' ? 'status-present' : 'status-missing'}">
                            ${p.status === 'present' ? '✅ Present' : '❌ Missing'}
                        </span>
                        <div class="icon">${getCategoryIcon(p.category)}</div>
                        <h3>${p.name}</h3>
                        <span class="category">${p.category}</span>
                        <div class="location">📍 ${p.location || 'No location set'}</div>
                        ${p.notes ? `<div class="notes">📝 ${p.notes}</div>` : ''}
                        <div class="card-actions">
                            ${p.status === 'present' 
                                ? `<button class="btn btn-checkout" onclick="updateStatus(${p.id}, 'missing')">❌ Mark Missing</button>`
                                : `<button class="btn btn-checkin" onclick="updateStatus(${p.id}, 'present')">✅ Mark Present</button>`
                            }
                            <button class="btn btn-edit" onclick="editProperty(${p.id})">✏️ Edit</button>
                            <button class="btn btn-delete" onclick="deleteProperty(${p.id})">🗑️</button>
                            <button class="btn btn-primary btn-sm" onclick="addToShoppingFromInventory('${p.name}', '${p.category}')">🛒</button>
                        </div>
                    </div>
                `).join('');
            }

            updateStats();
            checkMissingItems();
            document.getElementById('inventoryBadge').textContent = properties.length;
        }

        function getCategoryIcon(category) {
            const icons = {
                'Electronics': '📱',
                'Furniture': '🪑',
                'Clothing': '👕',
                'Books': '📚',
                'Tools': '🔧',
                'Food': '🍕',
                'Other': '📦'
            };
            return icons[category] || '📦';
        }

        // ============================================================
        // STATS
        // ============================================================
        function updateStats() {
            const total = properties.length;
            const present = properties.filter(p => p.status === 'present').length;
            const missing = properties.filter(p => p.status === 'missing').length;

            document.getElementById('totalItems').textContent = total;
            document.getElementById('presentItems').textContent = present;
            document.getElementById('missingItems').textContent = missing;
        }

        // ============================================================
        // ALERT SYSTEM
        // ============================================================
        function checkMissingItems() {
            const missing = properties.filter(p => p.status === 'missing');
            const banner = document.getElementById('alertBanner');
            const message = document.getElementById('alertMessage');

            if (missing.length > 0) {
                banner.classList.add('show');
                const names = missing.map(p => p.name).join(', ');
                message.textContent = `🚨 ${missing.length} item${missing.length > 1 ? 's' : ''} missing: ${names}`;
            } else {
                banner.classList.remove('show');
            }
        }

        function dismissAlert() {
            document.getElementById('alertBanner').classList.remove('show');
        }

        // ============================================================
        // INVENTORY: CRUD
        // ============================================================
        function openAddModal() {
            document.getElementById('modalTitle').textContent = '➕ Add New Property';
            document.getElementById('editId').value = '';
            document.getElementById('propertyForm').reset();
            document.getElementById('itemStatus').value = 'present';
            document.getElementById('saveBtn').textContent = '💾 Save Property';
            document.getElementById('addModal').classList.add('show');
        }

        function editProperty(id) {
            const p = properties.find(item => item.id === id);
            if (!p) return;

            document.getElementById('modalTitle').textContent = '✏️ Edit Property';
            document.getElementById('editId').value = id;
            document.getElementById('itemName').value = p.name;
            document.getElementById('itemCategory').value = p.category;
            document.getElementById('itemLocation').value = p.location || '';
            document.getElementById('itemStatus').value = p.status;
            document.getElementById('itemNotes').value = p.notes || '';
            document.getElementById('saveBtn').textContent = '💾 Update Property';
            document.getElementById('addModal').classList.add('show');
        }

        function saveProperty(e) {
            e.preventDefault();

            const id = document.getElementById('editId').value;
            const name = document.getElementById('itemName').value.trim();
            const category = document.getElementById('itemCategory').value;
            const location = document.getElementById('itemLocation').value.trim();
            const status = document.getElementById('itemStatus').value;
            const notes = document.getElementById('itemNotes').value.trim();

            if (!name) {
                showToast('Please enter an item name.', 'warning');
                return;
            }

            if (id) {
                const index = properties.findIndex(p => p.id === parseFloat(id));
                if (index !== -1) {
                    properties[index] = { ...properties[index], name, category, location, status, notes };
                }
                showToast(`✅ "${name}" updated successfully!`, 'success');
            } else {
                const newItem = { id: generateId(), name, category, location, status, notes };
                properties.push(newItem);
                showToast(`✅ "${name}" added successfully!`, 'success');
            }

            saveData();
            renderProperties();
            closeModal('addModal');
        }

        function updateStatus(id, newStatus) {
            const p = properties.find(item => item.id === id);
            if (!p) return;

            p.status = newStatus;
            saveData();
            renderProperties();

            if (newStatus === 'missing') {
                showToast(`❌ "${p.name}" marked as missing!`, 'error');
                checkMissingItems();
            } else {
                showToast(`✅ "${p.name}" marked as present!`, 'success');
                checkMissingItems();
            }
        }

        function deleteProperty(id) {
            const p = properties.find(item => item.id === id);
            if (!p) return;

            if (confirm(`Are you sure you want to delete "${p.name}"?`)) {
                properties = properties.filter(item => item.id !== id);
                saveData();
                renderProperties();
                showToast(`🗑️ "${p.name}" deleted.`, 'warning');
                checkMissingItems();
            }
        }

        function addToShoppingFromInventory(name, category) {
            if (shoppingItems.some(item => item.name === name)) {
                showToast(`"${name}" is already in your shopping list.`, 'warning');
                return;
            }

            const price = prompt(`Enter estimated price for "${name}" (e.g., ₦50,000, $200):`, '₦0');

            shoppingItems.push({
                id: generateId(),
                name: name,
                category: category,
                price: price || '₦0',
                notes: 'Added from inventory',
                purchased: false
            });
            saveData();
            renderShoppingList();
            document.getElementById('shoppingBadge').textContent = shoppingItems.filter(i => !i.purchased).length;
            showToast(`🛒 "${name}" added to shopping list!`, 'success');
            switchPage('shopping');
        }

        // ============================================================
        // SHOPPING LIST
        // ============================================================
        function renderShoppingList() {
            const search = document.getElementById('shoppingSearch').value.toLowerCase();

            let filtered = shoppingItems.filter(item =>
                item.name.toLowerCase().includes(search) ||
                item.category.toLowerCase().includes(search)
            );

            filtered.sort((a, b) => a.purchased - b.purchased);

            const grid = document.getElementById('shoppingGrid');

            if (filtered.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state">
                        <div class="icon">🛒</div>
                        <h3>Your Shopping List is Empty</h3>
                        <p>Add items you want to buy in the future.</p>
                        <button class="btn btn-primary" onclick="openShoppingModal()" style="margin-top:12px;">➕ Add Item</button>
                    </div>
                `;
            } else {
                grid.innerHTML = filtered.map(item => `
                    <div class="shopping-item ${item.purchased ? 'purchased' : ''}">
                        <input type="checkbox" class="checkbox" ${item.purchased ? 'checked' : ''} 
                               onchange="togglePurchased(${item.id})" />
                        <div class="item-info">
                            <div class="name">${item.name}</div>
                            <div class="details">
                                ${item.category} ${item.notes ? '• ' + item.notes : ''}
                            </div>
                        </div>
                        <div class="item-price">${item.price || '₦0'}</div>
                        <div class="item-actions">
                            <button class="btn btn-edit" onclick="editShoppingItem(${item.id})">✏️</button>
                            <button class="btn btn-delete" onclick="deleteShoppingItem(${item.id})">🗑️</button>
                        </div>
                    </div>
                `).join('');
            }

            updateTotal();
            document.getElementById('shoppingBadge').textContent = shoppingItems.filter(i => !i.purchased).length;
        }

        function updateTotal() {
            const total = shoppingItems
                .filter(item => !item.purchased)
                .reduce((sum, item) => {
                    const priceStr = item.price || '0';
                    const numbers = priceStr.replace(/[^0-9.]/g, '');
                    const num = parseFloat(numbers) || 0;
                    return sum + num;
                }, 0);

            const formatted = total.toLocaleString('en-US', {
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            });

            document.getElementById('totalAmount').textContent = `₦${formatted}`;
        }

        function openShoppingModal() {
            document.getElementById('shoppingEditId').value = '';
            document.getElementById('shoppingForm').reset();
            document.getElementById('shoppingPrice').value = '₦';
            document.getElementById('shoppingSaveBtn').textContent = '💾 Add to List';
            document.getElementById('shoppingModal').classList.add('show');
        }

        function editShoppingItem(id) {
            const item = shoppingItems.find(i => i.id === id);
            if (!item) return;

            document.getElementById('shoppingEditId').value = id;
            document.getElementById('shoppingName').value = item.name;
            document.getElementById('shoppingCategory').value = item.category;
            document.getElementById('shoppingPrice').value = item.price || '';
            document.getElementById('shoppingNotes').value = item.notes || '';
            document.getElementById('shoppingSaveBtn').textContent = '💾 Update Item';
            document.getElementById('shoppingModal').classList.add('show');
        }

        function saveShoppingItem(e) {
            e.preventDefault();

            const id = document.getElementById('shoppingEditId').value;
            const name = document.getElementById('shoppingName').value.trim();
            const category = document.getElementById('shoppingCategory').value;
            const price = document.getElementById('shoppingPrice').value.trim();
            const notes = document.getElementById('shoppingNotes').value.trim();

            if (!name) {
                showToast('Please enter an item name.', 'warning');
                return;
            }

            if (!price) {
                showToast('Please enter an estimated price.', 'warning');
                return;
            }

            if (id) {
                const index = shoppingItems.findIndex(i => i.id === parseFloat(id));
                if (index !== -1) {
                    shoppingItems[index] = { ...shoppingItems[index], name, category, price, notes };
                }
                showToast(`✅ "${name}" updated!`, 'success');
            } else {
                shoppingItems.push({ id: generateId(), name, category, price, notes, purchased: false });
                showToast(`🛒 "${name}" added to shopping list!`, 'success');
            }

            saveData();
            renderShoppingList();
            closeModal('shoppingModal');
        }

        function togglePurchased(id) {
            const item = shoppingItems.find(i => i.id === id);
            if (!item) return;
            item.purchased = !item.purchased;
            saveData();
            renderShoppingList();
            updateTotal();

            if (item.purchased) {
                showToast(`✅ "${item.name}" marked as purchased!`, 'success');
            } else {
                showToast(`↩️ "${item.name}" unmarked.`, 'warning');
            }
        }

        function deleteShoppingItem(id) {
            const item = shoppingItems.find(i => i.id === id);
            if (!item) return;

            if (confirm(`Remove "${item.name}" from shopping list?`)) {
                shoppingItems = shoppingItems.filter(i => i.id !== id);
                saveData();
                renderShoppingList();
                updateTotal();
                showToast(`🗑️ "${item.name}" removed.`, 'warning');
            }
        }

        function clearPurchased() {
            const purchased = shoppingItems.filter(i => i.purchased);
            if (purchased.length === 0) {
                showToast('No purchased items to clear.', 'warning');
                return;
            }

            if (confirm(`Remove ${purchased.length} purchased item(s) from the list?`)) {
                shoppingItems = shoppingItems.filter(i => !i.purchased);
                saveData();
                renderShoppingList();
                updateTotal();
                showToast(`🗑️ Cleared ${purchased.length} purchased items.`, 'success');
            }
        }

        // ============================================================
        // MODAL HELPERS
        // ============================================================
        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
        }

        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.remove('show');
                }
            });
        });

        // ============================================================
        // EXPORT / IMPORT
        // ============================================================
        function exportData() {
            const data = JSON.stringify({ properties, shoppingItems }, null, 2);
            const blob = new Blob([data], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `property_backup_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('📤 Data exported successfully!', 'success');
        }

        function importData() {
            document.getElementById('fileInput').click();
        }

        function handleImport(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const imported = JSON.parse(e.target.result);
                    if (imported.properties && Array.isArray(imported.properties) &&
                        imported.shoppingItems && Array.isArray(imported.shoppingItems)) {
                        if (confirm(`This will replace all current data. Continue?`)) {
                            properties = imported.properties;
                            shoppingItems = imported.shoppingItems;
                            saveData();
                            renderProperties();
                            renderShoppingList();
                            showToast(`📥 Imported ${properties.length} properties and ${shoppingItems.length} shopping items!`,
                                'success');
                        }
                    } else {
                        showToast('Invalid file format. Please import a valid backup file.', 'error');
                    }
                } catch (err) {
                    showToast('Error reading file. Please check the format.', 'error');
                }
            };
            reader.readAsText(file);
            event.target.value = '';
        }

        // ============================================================
        // TOAST
        // ============================================================
        function showToast(msg, type = '') {
            const existing = document.querySelector('.toast');
            if (existing) existing.remove();

            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.textContent = msg;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // ============================================================
        // PWA: INSTALL BANNER
        // ============================================================
        let deferredPrompt = null;

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            document.getElementById('installBanner').classList.add('show');
        });

        document.getElementById('installBtn').addEventListener('click', async () => {
            if (deferredPrompt) {
                const result = await deferredPrompt.prompt();
                if (result.outcome === 'accepted') {
                    showToast('✅ App installed successfully!', 'success');
                }
                deferredPrompt = null;
                document.getElementById('installBanner').classList.remove('show');
            }
        });

        function closeInstallBanner() {
            document.getElementById('installBanner').classList.remove('show');
        }

        // ============================================================
        // INIT
        // ============================================================
        loadData();
        renderProperties();
        renderShoppingList();

        document.getElementById('inventoryBadge').textContent = properties.length;
        document.getElementById('shoppingBadge').textContent = shoppingItems.filter(i => !i.purchased).length;

        setTimeout(checkMissingItems, 500);
    </script>

</body>
</html>
